{
  "name": "kepler",
  "main": "worker.js",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    // The worker must intercept every request to enforce the HTTPS
    // redirect and attach security headers to asset responses.
    "run_worker_first": true
  }
}
